# CareerOS Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CareerOS

# Optional: OAuth Providers (configure in Supabase Dashboard)
# Google OAuth is configured through Supabase Dashboard
# Go to Authentication > Providers > Google

# Optional: Email Configuration (Supabase handles this by default)
# For custom email provider, configure in Supabase Dashboard